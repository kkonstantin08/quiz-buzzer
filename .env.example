# Backend configuration
NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://postgres:postgres_password@postgres:5432/buzzer?schema=public
JWT_SECRET=super_secret_jwt_for_production
CORS_ORIGIN=http://localhost
UPLOAD_DIR=/app/uploads

# Frontend configuration
# In production, this should point to your public domain name or IP
VITE_API_URL=http://localhost/api
VITE_APP_PUBLIC_URL=http://localhost

# Seed admin user
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
SEED_SUBSCRIPTION_STATUS=active
SEED_SUBSCRIPTION_DAYS=365
