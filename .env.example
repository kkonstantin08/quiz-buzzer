# Backend configuration
NODE_ENV=production
PORT=3001
# Docker environment database path
DATABASE_URL=file:/app/prisma/dev.db
# Replace with a strong random string (e.g. openssl rand -base64 32)
JWT_SECRET=replace_me_with_random_string
CORS_ORIGIN=http://localhost
UPLOAD_DIR=/app/uploads
TRUST_PROXY=false
COOKIE_SECURE=false

# Frontend configuration
# In production, this should point to your public domain name or IP
VITE_API_URL=http://localhost/api
VITE_APP_PUBLIC_URL=http://localhost
VITE_YANDEX_METRIKA_ID=

# Feature flags
PAYMENTS_ENABLED=false
REGISTRATION_ENABLED=false
