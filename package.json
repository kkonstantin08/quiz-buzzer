{
  "name": "buzzer-mvp",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/backend\" \"npm run dev -w apps/frontend\"",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "concurrently": "^10.0.3",
    "lighthouse": "^13.4.0",
    "playwright": "^1.61.1",
    "puppeteer": "^25.3.0"
  },
  "overrides": {
    "tar": "^7.5.16"
  }
}
