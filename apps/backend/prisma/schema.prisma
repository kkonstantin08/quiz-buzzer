// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HostUser {
  id              String         @id @default(uuid())
  name            String?
  avatarUrl       String?
  email           String         @unique
  passwordHash    String
  freeTrialUsed   Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  subscription    Subscription?
  settings        HostSettings?
  gameHistory     GameHistory[]
}

model Subscription {
  id                 String   @id @default(uuid())
  hostUserId         String   @unique
  hostUser           HostUser @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  status             String   // active, inactive, expired, canceled
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model HostSettings {
  id             String   @id @default(uuid())
  hostUserId     String   @unique
  hostUser       HostUser @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  soundEnabled   Boolean  @default(true)
  soundTheme     String   @default("classic")
  customLogoUrl  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model GameHistory {
  id           String   @id @default(uuid())
  hostUserId   String
  hostUser     HostUser @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  roomCode     String
  winnerName   String
  winnerScore  Int
  participants Int
  createdAt    DateTime @default(now())
}
