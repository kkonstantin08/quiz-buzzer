// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model HostUser {
  id              String         @id @default(uuid())
  name            String?
  avatarUrl       String?
  email           String         @unique
  passwordHash    String
  freeTrialUsed   Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  subscription    Subscription?
  settings        HostSettings?
  gameHistory     GameHistory[]
  sessions        Session[]
  legalAcceptances LegalAcceptance[]
  payments        Payment[]
  paymentMethods  PaymentMethod[]
}

model Session {
  id         String    @id @default(uuid())
  userId     String
  user       HostUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
}

model Subscription {
  id                 String   @id @default(uuid())
  hostUserId         String   @unique
  hostUser           HostUser @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  status             String   // active, inactive, expired, canceled
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  autoRenew          Boolean  @default(false)
  cancelAtPeriodEnd  Boolean  @default(false)
  canceledAt         DateTime?
  nextChargeAt       DateTime?
  lastPaymentId      String?
  providerPaymentMethodId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model HostSettings {
  id             String   @id @default(uuid())
  hostUserId     String   @unique
  hostUser       HostUser @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  soundEnabled   Boolean  @default(true)
  soundTheme     String   @default("classic")
  customLogoUrl  String?
  customBgUrl    String?
  bgTheme        String   @default("light")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model GameHistory {
  id           String   @id @default(uuid())
  hostUserId   String
  hostUser     HostUser @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  roomCode     String
  winnerName   String
  winnerScore  Int
  participants Int
  createdAt    DateTime @default(now())
}

model LegalAcceptance {
  id               String                @id @default(uuid())
  hostUserId       String
  documentType     String                // TERMS, OFFER, RECURRING_PAYMENT, MARKETING, PRIVACY_ACKNOWLEDGEMENT
  documentVersion  String
  acceptanceSource String                // REGISTRATION, CHECKOUT, ACCOUNT_SETTINGS, DOCUMENT_UPDATE
  ipAddress        String?
  userAgent        String?
  acceptedAt       DateTime              @default(now())

  hostUser HostUser @relation(fields: [hostUserId], references: [id], onDelete: Cascade)

  @@unique([hostUserId, documentType, documentVersion])
  @@index([hostUserId])
}

model Payment {
  id                String    @id @default(uuid())
  hostUserId        String
  provider          String
  providerPaymentId String    @unique
  idempotencyKey    String    @unique
  amountMinor       Int
  currency          String
  status            String
  description       String?
  createdAt         DateTime  @default(now())
  paidAt            DateTime?
  updatedAt         DateTime  @updatedAt

  hostUser HostUser @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  refunds  Refund[]
}

model PaymentMethod {
  id                      String    @id @default(uuid())
  hostUserId              String
  provider                String
  providerPaymentMethodId String    @unique
  recurringEnabled        Boolean   @default(false)
  consentedAt             DateTime?
  disabledAt              DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  hostUser HostUser @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
}

model Refund {
  id               String   @id @default(uuid())
  paymentId        String
  providerRefundId String   @unique
  amountMinor      Int
  currency         String
  status           String
  reason           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}
